{
  "name": "ai-ocr-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI OCR Dashboard - Monorepo with backend services",
  "workspaces": [
    "apps/backend-services",
    "apps/frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "cd apps/backend-services && npm run start:dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend-services": "cd apps/backend-services && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "build": "npm run build:backend-services && npm run build:frontend",
    "install:all": "npm install && cd apps/backend-services && npm install && cd ../frontend && npm install",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:api-auth": "playwright test tests/e2e/api-key-auth.spec.ts",
    "test:frontend-mock": "playwright test tests/e2e/frontend-with-mock-auth.spec.ts",
    "test:training-labels": "playwright test tests/e2e/training-labels-with-api-key.spec.ts",
    "setup:test-api-key": "node scripts/create-test-api-key.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@playwright/test": "^1.58.2",
    "apollo-server-express": "^3.13.0"
  }
}
