{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Heap Usage",
      "description": "Node.js heap memory usage over time (used, total, and external/process heap)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "bytes",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "sum by (space) (nodejs_heap_space_size_used_bytes)",
          "legendFormat": "Used ({{ space }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "sum(nodejs_heap_space_size_total_bytes)",
          "legendFormat": "Heap Total",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "process_heap_bytes",
          "legendFormat": "Process Heap (external)",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Event Loop Lag",
      "description": "Node.js event loop lag in seconds, indicating how long asynchronous callbacks wait before being executed",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "Event Loop Lag",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "nodejs_eventloop_lag_mean_seconds",
          "legendFormat": "Mean Lag",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "p99 Lag",
          "refId": "C"
        }
      ]
    },
    {
      "title": "GC Pause Durations",
      "description": "Garbage collection pause durations by GC type (major, minor, incremental, etc.)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "rate(nodejs_gc_duration_seconds_sum[5m]) / rate(nodejs_gc_duration_seconds_count[5m])",
          "legendFormat": "Avg Duration ({{ kind }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(nodejs_gc_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 ({{ kind }})",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, kind) (rate(nodejs_gc_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 ({{ kind }})",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Active Handles",
      "description": "Number of active handles (sockets, timers, etc.) in the Node.js process",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "handles",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "nodejs_active_handles_total",
          "legendFormat": "Active Handles",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nodejs", "runtime", "performance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "includeAll": false,
        "name": "prometheus_datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "Node.js Runtime",
  "uid": "nodejs-runtime",
  "version": 1,
  "refresh": "30s"
}
