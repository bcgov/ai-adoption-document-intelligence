# =============================================================================
# Prod Environment Configuration
# =============================================================================
# Profile: prod
# Purpose: Default configuration for production deployments on OpenShift.
# Secrets (API keys, client secrets, connection strings) are NOT stored here;
# they are managed via OpenShift Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenShift Cluster / Routing
# -----------------------------------------------------------------------------
# The cluster wildcard domain. On BC Gov Silver this is apps.silver.devops.gov.bc.ca.
# The deploy script computes ROUTE_HOST_SUFFIX as <namespace>.<CLUSTER_DOMAIN> automatically.
CLUSTER_DOMAIN=apps.silver.devops.gov.bc.ca

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3002
BODY_LIMIT=50mb

# -----------------------------------------------------------------------------
# SSO / Keycloak (per environment profile, not per instance)
# -----------------------------------------------------------------------------
SSO_AUTH_SERVER_URL=https://your-sso-provider.example.com/auth/realms/your-realm/protocol/openid-connect
SSO_REALM=your-realm
SSO_CLIENT_ID=your-client-id
# SSO_REDIRECT_URI is computed at deploy time from INSTANCE_NAME and ROUTE_HOST_SUFFIX

# Frontend SSO build args
VITE_SSO_AUTH_SERVER_URL=https://your-sso-provider.example.com/auth/realms/your-realm/protocol/openid-connect
VITE_SSO_REALM=your-realm
VITE_SSO_CLIENT_ID=your-client-id

# -----------------------------------------------------------------------------
# Azure Document Intelligence (per environment profile, not per instance)
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-prod-region.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-read
AZURE_DOC_INTELLIGENCE_MODELS=prebuilt-layout,prebuilt-document

# -----------------------------------------------------------------------------
# Azure Blob Storage (per environment profile, not per instance)
# -----------------------------------------------------------------------------
BLOB_STORAGE_PROVIDER=azure
AZURE_STORAGE_CONTAINER_NAME=document-blobs

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
# TEMPORAL_ADDRESS is computed at deploy time from INSTANCE_NAME
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ocr-processing
BENCHMARK_TASK_QUEUE=benchmark-processing
ENABLE_BENCHMARK_QUEUE=true

# -----------------------------------------------------------------------------
# Database SSL (Crunchy Postgres on OpenShift)
# -----------------------------------------------------------------------------
PGSSLMODE=require
PGSSLREJECTUNAUTHORIZED=false

# -----------------------------------------------------------------------------
# Frontend Build Args
# -----------------------------------------------------------------------------
VITE_APP_NAME=My App Frontend
VITE_APP_VERSION=1.0.0
VITE_ENV=prod

# -----------------------------------------------------------------------------
# Rate Limiting (stricter production defaults)
# -----------------------------------------------------------------------------
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=5
THROTTLE_AUTH_REFRESH_TTL_MS=60000
THROTTLE_AUTH_REFRESH_LIMIT=3
