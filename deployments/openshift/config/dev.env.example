# =============================================================================
# Dev Environment Configuration
# =============================================================================
# Profile: dev
# Purpose: All configuration for development deployments on OpenShift,
# including secrets. This file is gitignored — copy from dev.env.example
# and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenShift Cluster / Routing
# -----------------------------------------------------------------------------
# The cluster wildcard domain. On BC Gov Silver this is apps.silver.devops.gov.bc.ca.
# The deploy script computes ROUTE_HOST_SUFFIX as <namespace>.<CLUSTER_DOMAIN> automatically.
CLUSTER_DOMAIN=apps.silver.devops.gov.bc.ca

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3002
BODY_LIMIT=50mb

# -----------------------------------------------------------------------------
# SSO / Keycloak
# -----------------------------------------------------------------------------
SSO_AUTH_SERVER_URL=https://dev.your-sso-provider.example.com/auth/realms/your-realm/protocol/openid-connect
SSO_REALM=your-realm
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-sso-client-secret-here
# SSO_REDIRECT_URI is computed at deploy time from INSTANCE_NAME and ROUTE_HOST_SUFFIX

# Frontend SSO build args
VITE_SSO_AUTH_SERVER_URL=https://dev.your-sso-provider.example.com/auth/realms/your-realm/protocol/openid-connect
VITE_SSO_REALM=your-realm
VITE_SSO_CLIENT_ID=your-client-id

# -----------------------------------------------------------------------------
# Azure Document Intelligence
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-dev-region.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your-azure-doc-intelligence-api-key-here
AZURE_DOC_INTELLIGENCE_MODELS=prebuilt-layout,prebuilt-document

# -----------------------------------------------------------------------------
# Azure Blob Storage
# -----------------------------------------------------------------------------
BLOB_STORAGE_PROVIDER=azure
AZURE_STORAGE_CONTAINER_NAME=document-blobs
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string-here
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name-here
AZURE_STORAGE_ACCOUNT_KEY=your-azure-storage-account-key-here

# -----------------------------------------------------------------------------
# Azure OpenAI (LLM enrichment in Temporal worker)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-dev-openai.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview
ENRICHMENT_REDACT_PII=false

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
# TEMPORAL_ADDRESS is computed at deploy time from INSTANCE_NAME
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ocr-processing
BENCHMARK_TASK_QUEUE=benchmark-processing
ENABLE_BENCHMARK_QUEUE=true

# -----------------------------------------------------------------------------
# Database SSL (Crunchy Postgres on OpenShift)
# -----------------------------------------------------------------------------
PGSSLMODE=require
PGSSLREJECTUNAUTHORIZED=false

# -----------------------------------------------------------------------------
# Frontend Build Args
# -----------------------------------------------------------------------------
VITE_APP_NAME=My App Frontend
VITE_APP_VERSION=1.0.0
VITE_ENV=dev

# -----------------------------------------------------------------------------
# Rate Limiting (sensible dev defaults)
# -----------------------------------------------------------------------------
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_REFRESH_TTL_MS=60000
THROTTLE_AUTH_REFRESH_LIMIT=5
