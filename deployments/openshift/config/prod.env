# =============================================================================
# Prod Environment Configuration
# =============================================================================
# Profile: prod
# Purpose: Default configuration for production deployments on OpenShift.
# Secrets (API keys, client secrets, connection strings) are NOT stored here;
# they are managed via OpenShift Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenShift Cluster / Routing
# -----------------------------------------------------------------------------
ROUTE_HOST_SUFFIX=fd34fb-prod.apps.silver.devops.gov.bc.ca

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3002
BODY_LIMIT=50mb

# Frontend and backend URLs are generated per-instance at deploy time.
# These serve as fallback templates; the deploy script replaces INSTANCE_NAME.
FRONTEND_URL=https://INSTANCE_NAME-frontend-fd34fb-prod.apps.silver.devops.gov.bc.ca
BACKEND_URL=https://INSTANCE_NAME-backend-services-fd34fb-prod.apps.silver.devops.gov.bc.ca

# -----------------------------------------------------------------------------
# SSO / Keycloak (per environment profile, not per instance)
# -----------------------------------------------------------------------------
SSO_AUTH_SERVER_URL=https://loginproxy.gov.bc.ca/auth/realms/standard/protocol/openid-connect
SSO_REALM=standard
SSO_CLIENT_ID=ai-adoption-document-intelligence-6162
SSO_REDIRECT_URI=https://INSTANCE_NAME-backend-services-fd34fb-prod.apps.silver.devops.gov.bc.ca/api/auth/callback

# Frontend SSO build args
VITE_SSO_AUTH_SERVER_URL=https://loginproxy.gov.bc.ca/auth/realms/standard/protocol/openid-connect
VITE_SSO_REALM=standard
VITE_SSO_CLIENT_ID=ai-adoption-document-intelligence-6162

# -----------------------------------------------------------------------------
# Azure Document Intelligence (per environment profile, not per instance)
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-prod-region.api.cognitive.microsoft.com
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-read
AZURE_DOC_INTELLIGENCE_MODELS=prebuilt-layout,prebuilt-document

# -----------------------------------------------------------------------------
# Azure Blob Storage (per environment profile, not per instance)
# -----------------------------------------------------------------------------
BLOB_STORAGE_PROVIDER=azure
AZURE_STORAGE_CONTAINER_NAME=document-blobs

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
# In-cluster Temporal address (prefixed per-instance at deploy time)
TEMPORAL_ADDRESS=INSTANCE_NAME-temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ocr-processing
BENCHMARK_TASK_QUEUE=benchmark-processing
ENABLE_BENCHMARK_QUEUE=true

# -----------------------------------------------------------------------------
# Database SSL (Crunchy Postgres on OpenShift)
# -----------------------------------------------------------------------------
PGSSLMODE=require
PGSSLREJECTUNAUTHORIZED=false

# -----------------------------------------------------------------------------
# Frontend Build Args
# -----------------------------------------------------------------------------
VITE_APP_NAME=AI OCR Frontend
VITE_APP_VERSION=1.0.0
VITE_ENV=prod

# -----------------------------------------------------------------------------
# Rate Limiting (stricter production defaults)
# -----------------------------------------------------------------------------
THROTTLE_GLOBAL_TTL_MS=60000
THROTTLE_GLOBAL_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=5
THROTTLE_AUTH_REFRESH_TTL_MS=60000
THROTTLE_AUTH_REFRESH_LIMIT=3
