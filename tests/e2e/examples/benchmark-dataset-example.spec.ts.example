/**
 * Example E2E Test for Benchmarking Dataset APIs
 *
 * This is an EXAMPLE file showing how to use the dataset test helpers.
 * Rename to .spec.ts when you're ready to use it.
 *
 * To run:
 * 1. Ensure all services are running (MinIO, MLflow, Postgres)
 * 2. Rename this file to remove .example extension
 * 3. Run: npm run test:e2e
 */

import { test, expect } from "@playwright/test";
import {
  createTempDatasetRepo,
  type TempDatasetRepo,
} from "../../../apps/backend-services/src/testUtils/datasetTestHelpers";

test.describe("Benchmarking Dataset APIs", () => {
  let repo: TempDatasetRepo;
  let apiKey: string;

  test.beforeAll(async ({ request }) => {
    // Create a temporary dataset repository
    repo = await createTempDatasetRepo("e2e-dataset-");

    // Create an API key for authentication (reuse existing pattern)
    const response = await request.post("http://localhost:3002/api/api-keys", {
      headers: {
        // Add your auth headers here
      },
      data: {
        name: "E2E Test Key",
      },
    });

    const data = await response.json();
    apiKey = data.key;
  });

  test.afterAll(async () => {
    // Cleanup the temporary repository
    if (repo) {
      await repo.cleanup();
    }
  });

  test("should create a dataset with temp repository URL", async ({
    request,
  }) => {
    const response = await request.post(
      "http://localhost:3002/api/benchmark/datasets",
      {
        headers: {
          "X-API-Key": apiKey,
          "Content-Type": "application/json",
        },
        data: {
          name: "Test Dataset",
          description: "Dataset created with temp repository",
          repositoryUrl: repo.url, // Uses file:// URL with temp directory
          dvcRemote: "minio",
          metadata: {
            type: "test",
          },
        },
      },
    );

    expect(response.status()).toBe(201);

    const dataset = await response.json();
    expect(dataset.name).toBe("Test Dataset");
    expect(dataset.repositoryUrl).toBe(repo.url);
  });

  test("should create dataset with tilde path", async ({ request }) => {
    // You can also use ~/path which will be expanded by the backend
    const response = await request.post(
      "http://localhost:3002/api/benchmark/datasets",
      {
        headers: {
          "X-API-Key": apiKey,
          "Content-Type": "application/json",
        },
        data: {
          name: "Dataset with Tilde",
          description: "Dataset using tilde expansion",
          repositoryUrl: "~/Github/datasets-repo", // Will be expanded to /home/username/Github/datasets-repo
          dvcRemote: "minio",
          metadata: {
            type: "test",
          },
        },
      },
    );

    expect(response.status()).toBe(201);
  });

  test("should handle multiple datasets with different repos", async ({
    request,
  }) => {
    // Create additional temp repos for testing
    const repo1 = await createTempDatasetRepo("dataset1-");
    const repo2 = await createTempDatasetRepo("dataset2-");

    try {
      // Create datasets with different repositories
      const [response1, response2] = await Promise.all([
        request.post("http://localhost:3002/api/benchmark/datasets", {
          headers: { "X-API-Key": apiKey, "Content-Type": "application/json" },
          data: {
            name: "Dataset 1",
            repositoryUrl: repo1.url,
            dvcRemote: "minio",
          },
        }),
        request.post("http://localhost:3002/api/benchmark/datasets", {
          headers: { "X-API-Key": apiKey, "Content-Type": "application/json" },
          data: {
            name: "Dataset 2",
            repositoryUrl: repo2.url,
            dvcRemote: "minio",
          },
        }),
      ]);

      expect(response1.status()).toBe(201);
      expect(response2.status()).toBe(201);

      const dataset1 = await response1.json();
      const dataset2 = await response2.json();

      expect(dataset1.repositoryUrl).toBe(repo1.url);
      expect(dataset2.repositoryUrl).toBe(repo2.url);
      expect(dataset1.repositoryUrl).not.toBe(dataset2.repositoryUrl);
    } finally {
      // Clean up additional repos
      await repo1.cleanup();
      await repo2.cleanup();
    }
  });
});
