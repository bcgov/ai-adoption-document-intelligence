graph TB
    %% ── External Actors ──────────────────────────────────────────
    Users["Human Users<br/>(Browser)"]
    APIConsumers["API Consumers<br/>(Programmatic)"]

    %% ── External Services ────────────────────────────────────────
    Keycloak["Keycloak<br/>OIDC / SSO Provider"]
    AzureDI["Azure Document<br/>Intelligence<br/>(OCR API)"]
    AzureBlob["Azure Blob Storage<br/>(production)"]

    %% ── Application Services ─────────────────────────────────────
    subgraph Platform ["Document Intelligence Platform"]
        direction TB

        subgraph FE ["Frontend &lpar;React 19 SPA&rpar;"]
            direction LR
            DocUpload["Document Upload"]
            WorkflowEditor["Workflow Editor<br/>(JSON + ReactFlow)"]
            LabelingWS["Labeling Workspace<br/>(Canvas / Konva)"]
            HITLReview["HITL Review<br/>Queue + Workspace"]
            TrainingDash["Training Dashboard"]
            SettingsPage["Settings / API Keys"]
        end

        subgraph BE ["Backend Services &lpar;NestJS / Fastify :3002&rpar;"]
            direction LR
            UploadMod["Upload<br/>Module"]
            DocMod["Document<br/>Module"]
            WorkflowMod["Workflow<br/>Module"]
            LabelingMod["Labeling<br/>Module"]
            HITLMod["HITL<br/>Module"]
            TrainingMod["Training<br/>Module"]
            AzureMod["Azure<br/>Module"]
            OcrMod["OCR<br/>Module"]
            AuthMod["Auth Module<br/>(JWT + API Key)"]
            DbMod["Database Module<br/>(Prisma)"]
            BlobMod["Blob Storage<br/>Module"]
            TemporalClient["Temporal Client<br/>Module"]
        end

        subgraph TS ["Temporal Server &lpar;:7233 gRPC / :8080 UI&rpar;"]
            TemporalSrv["Workflow History<br/>Task Dispatch<br/>Signal & Query<br/>Namespace: default<br/>Queue: ocr-processing"]
        end

        subgraph TW ["Temporal Worker &lpar;apps/temporal&rpar;"]
            direction TB
            GraphWF["graphWorkflow&lpar;&rpar;<br/>DAG Runner"]
            ActivityReg["Activity Registry<br/>(15 activities)"]
            NodeInterp["Node Interpreters<br/>activity | switch | map<br/>join | childWorkflow<br/>pollUntil | humanGate"]
            ExprEval["Expression<br/>Evaluator"]
        end
    end

    %% ── Data Stores ──────────────────────────────────────────────
    PG[("PostgreSQL<br/>(Prisma ORM)")]
    LocalBlob[("Blob Storage<br/>(local fs / Azure)")]

    %% ── Standalone ───────────────────────────────────────────────
    ImageSvc["Image Service<br/>(Python / OpenCV)<br/><i>standalone utility</i>"]

    %% ── Connections: External Actors ─────────────────────────────
    Users -->|"HTTPS"| FE
    APIConsumers -->|"HTTPS + x-api-key"| BE

    %% ── Connections: Frontend ↔ Backend ──────────────────────────
    FE -->|"HTTP REST<br/>(Axios / Vite proxy)"| BE

    %% ── Connections: Backend → External Services ─────────────────
    AuthMod -->|"JWKS / JWT"| Keycloak
    AzureMod -->|"REST API"| AzureDI
    AzureMod -->|"Azure SDK"| AzureBlob
    OcrMod -->|"REST API"| AzureDI
    TrainingMod -->|"REST API<br/>+ Azure SDK"| AzureDI
    TrainingMod -->|"Azure SDK"| AzureBlob

    %% ── Connections: Backend → Data Stores ───────────────────────
    DbMod --> PG
    BlobMod --> LocalBlob
    TemporalClient -->|"gRPC"| TemporalSrv

    %% ── Connections: Temporal Server ↔ Worker ────────────────────
    TemporalSrv -->|"task dispatch"| TW

    %% ── Connections: Worker internals ────────────────────────────
    GraphWF --> ActivityReg
    GraphWF --> NodeInterp
    GraphWF --> ExprEval

    %% ── Connections: Worker → Shared Data Stores ─────────────────
    ActivityReg -->|"Prisma"| PG
    ActivityReg -->|"filesystem /<br/>Azure SDK"| LocalBlob
    ActivityReg -->|"REST API"| AzureDI

    %% ── Styling ──────────────────────────────────────────────────
    classDef external fill:#f9f0ff,stroke:#7c3aed,stroke-width:2px
    classDef service fill:#eff6ff,stroke:#2563eb,stroke-width:2px
    classDef datastore fill:#ecfdf5,stroke:#059669,stroke-width:2px
    classDef standalone fill:#fef3c7,stroke:#d97706,stroke-width:1px,stroke-dasharray:5

    class Users,APIConsumers,Keycloak,AzureDI,AzureBlob external
    class FE,BE,TS,TW service
    class PG,LocalBlob datastore
    class ImageSvc standalone
