graph TB
    %% ── Entry Point ──────────────────────────────────────────────
    WorkerTS["worker.ts<br/>(entrypoint)"]

    WorkerTS -->|"gRPC connect"| TemporalSrv["Temporal Server<br/>:7233"]
    WorkerTS -->|"register"| GraphWF
    WorkerTS -->|"load"| Registry

    %% ── graphWorkflow ────────────────────────────────────────────
    subgraph GWF ["graphWorkflow&lpar;input: GraphWorkflowInput&rpar;"]
        direction TB

        PreHook["1. Pre-execution Hook<br/>updateDocumentStatus → ongoing_ocr"]
        Validator["2. Graph Schema Validator<br/>cycle detection, node/edge integrity"]
        InitCtx["3. Initialize Context &lpar;ctx&rpar;<br/>merge initialCtx + graph defaults"]
        TopoSort["4. Topological Sort<br/>stable sort, alphabetical tiebreak"]

        PreHook --> Validator --> InitCtx --> TopoSort

        TopoSort --> ExecLoop

        subgraph ExecLoop ["5. Main Execution Loop"]
            direction TB

            subgraph NodeTypes ["Node Type Interpreters"]
                direction LR
                ActivityNode["<b>activity</b><br/>resolve registry key<br/>→ proxyActivities&lpar;&rpar;<br/>read ctx → call<br/>→ write ctx"]
                SwitchNode["<b>switch</b><br/>evaluate cases<br/>via Expression<br/>Evaluator<br/>→ follow edge"]
                MapNode["<b>map</b> &lpar;fan-out&rpar;<br/>iterate collection<br/>spawn parallel<br/>branches<br/>maxConcurrency"]
                JoinNode["<b>join</b> &lpar;fan-in&rpar;<br/>wait for map<br/>branches<br/>collect results<br/>→ ctx array"]
            end

            subgraph NodeTypes2 ["Node Type Interpreters (continued)"]
                direction LR
                ChildWF["<b>childWorkflow</b><br/>start child<br/>graphWorkflow<br/>map parent↔child ctx"]
                PollNode["<b>pollUntil</b><br/>activity + sleep loop<br/>Expression Evaluator<br/>for stop condition"]
                HumanNode["<b>humanGate</b><br/>register signal handler<br/>condition&lpar;&rpar; + timer<br/>onTimeout: fail /<br/>continue / fallback"]
            end
        end

        ExecLoop --> Result["6. Return<br/>{ ctx, completedNodes, status }"]
    end

    %% ── Expression Evaluator ─────────────────────────────────────
    subgraph ExprEval ["Expression Evaluator"]
        direction LR
        Operators["Operators:<br/>equals | not-equals | gt | gte<br/>lt | lte | contains<br/>and | or | not<br/>is-null | is-not-null<br/>in | not-in"]
        ValueRefs["Value References:<br/>ctx.key | ctx.key.nested<br/>literal values"]
    end

    SwitchNode -.-> ExprEval
    PollNode -.-> ExprEval

    %% ── Activity Registry ────────────────────────────────────────
    subgraph Registry ["Activity Registry &lpar;15 registered activities&rpar;"]
        direction TB

        subgraph DBActivities ["PostgreSQL Activities"]
            direction LR
            A1["document.updateStatus"]
            A2["ocr.storeResults"]
            A3["document.storeRejection"]
            A4["getWorkflowGraphConfig"]
        end

        subgraph AzureActivities ["Azure DI Activities"]
            direction LR
            A5["azureOcr.submit"]
            A6["azureOcr.poll"]
            A7["azureOcr.extract<br/>(pure transform)"]
        end

        subgraph BlobActivities ["Blob Storage Activities"]
            direction LR
            A8["file.prepare"]
            A9["document.split<br/>(qpdf + blob I/O)"]
            A10["document.splitAndClassify"]
        end

        subgraph PureActivities ["Pure Compute Activities"]
            direction LR
            A11["ocr.cleanup"]
            A12["ocr.checkConfidence"]
            A13["document.classify"]
            A14["document.validateFields"]
            A15["segment.combineResult"]
        end
    end

    ActivityNode -->|"resolve<br/>activityType"| Registry

    %% ── External Resources ───────────────────────────────────────
    PG[("PostgreSQL<br/>(Prisma)")]
    AzureDI["Azure Document<br/>Intelligence"]
    BlobStore[("Blob Storage<br/>(local fs / Azure)")]

    DBActivities --> PG
    AzureActivities -->|"REST API"| AzureDI
    BlobActivities --> BlobStore

    %% ── Query & Signal Handlers ──────────────────────────────────
    subgraph Handlers ["Query & Signal Handlers"]
        direction LR
        QGetStatus["query: getStatus<br/>currentNodes, nodeStatuses,<br/>overallStatus, ctx"]
        QGetProgress["query: getProgress<br/>completedCount, totalCount,<br/>progressPercentage"]
        SCancel["signal: cancel<br/>graceful / immediate"]
        SHumanGate["signal: dynamic<br/>humanGate signals<br/>(per node config)"]
    end

    GWF -.-> Handlers

    %% ── Styling ──────────────────────────────────────────────────
    classDef external fill:#f9f0ff,stroke:#7c3aed,stroke-width:2px
    classDef engine fill:#eff6ff,stroke:#2563eb,stroke-width:2px
    classDef nodeType fill:#fef3c7,stroke:#d97706,stroke-width:1px
    classDef activity fill:#ecfdf5,stroke:#059669,stroke-width:1px
    classDef datastore fill:#f0fdf4,stroke:#16a34a,stroke-width:2px

    class TemporalSrv,AzureDI external
    class GWF,ExecLoop engine
    class ActivityNode,SwitchNode,MapNode,JoinNode,ChildWF,PollNode,HumanNode nodeType
    class A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11,A12,A13,A14,A15 activity
    class PG,BlobStore datastore
