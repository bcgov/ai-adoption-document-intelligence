{
  "schemaVersion": "1.0",
  "metadata": {
    "name": "Standard OCR Workflow (Mistral)",
    "description": "Same post-processing and HITL as Standard OCR, using Mistral Document AI OCR instead of Azure submit/poll/extract",
    "tags": ["ocr", "mistral", "standard"]
  },
  "entryNodeId": "prepareFileData",
  "ctx": {
    "documentId": { "type": "string", "description": "Document ID from database" },
    "blobKey": { "type": "string", "description": "File reference on local storage" },
    "fileName": { "type": "string" },
    "fileType": { "type": "string" },
    "contentType": { "type": "string" },
    "modelId": { "type": "string", "defaultValue": "mistral-ocr-latest" },
    "templateModelId": {
      "type": "string",
      "defaultValue": "cmo8w9bsx0009loe5e1rxwhau",
      "description": "Labeling TemplateModel id (documents table metadata.templateModelId overrides this when set). Mistral requests document_annotation from field_schema when non-empty."
    },
    "confidenceThreshold": { "type": "number", "defaultValue": 0.95, "description": "OCR confidence threshold for human review" },
    "preparedFileData": { "type": "object" },
    "ocrResult": { "type": "object" },
    "cleanedResult": { "type": "object" },
    "averageConfidence": { "type": "number" },
    "requiresReview": { "type": "boolean", "defaultValue": false }
  },
  "nodes": {
    "prepareFileData": {
      "id": "prepareFileData",
      "type": "activity",
      "label": "Prepare File Data",
      "activityType": "file.prepare",
      "inputs": [
        { "port": "blobKey", "ctxKey": "blobKey" },
        { "port": "fileName", "ctxKey": "fileName" },
        { "port": "fileType", "ctxKey": "fileType" },
        { "port": "contentType", "ctxKey": "contentType" },
        { "port": "modelId", "ctxKey": "modelId" }
      ],
      "outputs": [{ "port": "preparedData", "ctxKey": "preparedFileData" }],
      "timeout": { "startToClose": "1m" },
      "retry": { "maximumAttempts": 3 }
    },
    "mistralOcr": {
      "id": "mistralOcr",
      "type": "activity",
      "label": "Mistral Document AI OCR",
      "activityType": "mistralOcr.process",
      "inputs": [
        { "port": "fileData", "ctxKey": "preparedFileData" },
        { "port": "templateModelId", "ctxKey": "templateModelId" }
      ],
      "outputs": [{ "port": "ocrResult", "ctxKey": "ocrResult" }],
      "timeout": { "startToClose": "10m" },
      "retry": { "maximumAttempts": 2 }
    },
    "postOcrCleanup": {
      "id": "postOcrCleanup",
      "type": "activity",
      "label": "Post-OCR Cleanup",
      "activityType": "ocr.cleanup",
      "inputs": [{ "port": "ocrResult", "ctxKey": "ocrResult" }],
      "outputs": [{ "port": "cleanedResult", "ctxKey": "cleanedResult" }],
      "timeout": { "startToClose": "2m" },
      "retry": { "maximumAttempts": 3 }
    },
    "checkConfidence": {
      "id": "checkConfidence",
      "type": "activity",
      "label": "Check OCR Confidence",
      "activityType": "ocr.checkConfidence",
      "inputs": [
        { "port": "documentId", "ctxKey": "documentId" },
        { "port": "ocrResult", "ctxKey": "cleanedResult" },
        { "port": "threshold", "ctxKey": "confidenceThreshold" }
      ],
      "outputs": [
        { "port": "averageConfidence", "ctxKey": "averageConfidence" },
        { "port": "requiresReview", "ctxKey": "requiresReview" }
      ],
      "timeout": { "startToClose": "30s" },
      "retry": { "maximumAttempts": 3 }
    },
    "reviewSwitch": {
      "id": "reviewSwitch",
      "type": "switch",
      "label": "Needs Review?",
      "inputs": [{ "port": "requiresReview", "ctxKey": "requiresReview" }],
      "cases": [
        {
          "condition": {
            "operator": "equals",
            "left": { "ref": "ctx.requiresReview" },
            "right": { "literal": true }
          },
          "edgeId": "edge-switch-to-humanGate"
        }
      ],
      "defaultEdge": "edge-switch-to-store"
    },
    "humanReview": {
      "id": "humanReview",
      "type": "humanGate",
      "label": "Human Review",
      "signal": {
        "name": "humanApproval",
        "payloadSchema": {
          "approved": "boolean",
          "reviewer": "string",
          "comments": "string",
          "rejectionReason": "string",
          "annotations": "string"
        }
      },
      "timeout": "24h",
      "onTimeout": "fail"
    },
    "storeResults": {
      "id": "storeResults",
      "type": "activity",
      "label": "Store Results",
      "activityType": "ocr.storeResults",
      "inputs": [
        { "port": "documentId", "ctxKey": "documentId" },
        { "port": "ocrResult", "ctxKey": "cleanedResult" }
      ],
      "timeout": { "startToClose": "2m" },
      "retry": { "maximumAttempts": 5 }
    }
  },
  "edges": [
    { "id": "e-m1", "source": "prepareFileData", "target": "mistralOcr", "type": "normal" },
    { "id": "e-m2", "source": "mistralOcr", "target": "postOcrCleanup", "type": "normal" },
    { "id": "e-m3", "source": "postOcrCleanup", "target": "checkConfidence", "type": "normal" },
    { "id": "e-m4", "source": "checkConfidence", "target": "reviewSwitch", "type": "normal" },
    { "id": "edge-switch-to-humanGate", "source": "reviewSwitch", "target": "humanReview", "type": "conditional", "condition": "requiresReview" },
    { "id": "edge-switch-to-store", "source": "reviewSwitch", "target": "storeResults", "type": "conditional", "condition": "default" },
    { "id": "e-m7", "source": "humanReview", "target": "storeResults", "type": "normal" }
  ],
  "nodeGroups": {
    "ocr-extraction": {
      "label": "OCR (Mistral)",
      "description": "Mistral Document AI synchronous OCR",
      "icon": "scan",
      "color": "#f97316",
      "nodeIds": ["prepareFileData", "mistralOcr"],
      "exposedParams": [
        {
          "label": "OCR Model",
          "path": "ctx.modelId.defaultValue",
          "type": "select",
          "options": ["mistral-ocr-latest"],
          "default": "mistral-ocr-latest"
        }
      ]
    },
    "cleanup": {
      "label": "Post-Processing",
      "description": "Clean and normalize OCR results",
      "icon": "cleanup",
      "color": "#22c55e",
      "nodeIds": ["postOcrCleanup"]
    },
    "quality-gate": {
      "label": "Quality Gate",
      "description": "Check OCR confidence and decide if human review is needed",
      "icon": "quality",
      "color": "#fb923c",
      "nodeIds": ["checkConfidence", "reviewSwitch"],
      "exposedParams": [
        {
          "label": "Confidence Threshold",
          "path": "nodes.checkConfidence.parameters.threshold",
          "type": "number",
          "default": 0.95
        }
      ]
    },
    "human-review": {
      "label": "Human Review",
      "description": "Wait for human approval when confidence is low",
      "icon": "human",
      "color": "#ef4444",
      "nodeIds": ["humanReview"],
      "exposedParams": [
        {
          "label": "Review Timeout",
          "path": "nodes.humanReview.timeout",
          "type": "duration",
          "default": "24h"
        }
      ]
    },
    "store": {
      "label": "Store Results",
      "description": "Save processed results to database",
      "icon": "save",
      "color": "#8b5cf6",
      "nodeIds": ["storeResults"]
    }
  }
}
