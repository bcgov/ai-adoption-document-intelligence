{
  "schemaVersion": "1.0",
  "metadata": {
    "name": "Experiment 02 - Mistral Document AI on Azure Foundry",
    "description": "E02: Mistral Document AI accessed via the Azure AI Foundry serverless deployment (mistral-document-ai-2512), parallel to the public-API path. Sync OCR + document_annotation in a single HTTP call; same canonical post-processing chain (cleanup → checkConfidence) and HITL gate as the public-API Mistral template. Forks the Mistral provider to keep the public-API path intact for fallback comparison.",
    "tags": ["ocr", "mistral", "azure-foundry", "experiment", "experiment-02"],
    "targetLocalDataset": "samples-mix-private"
  },
  "entryNodeId": "prepareFileData",
  "ctx": {
    "documentId": { "type": "string", "description": "Document ID from database" },
    "blobKey": { "type": "string", "description": "File reference on local storage" },
    "fileName": { "type": "string" },
    "fileType": { "type": "string" },
    "contentType": { "type": "string" },
    "modelId": {
      "type": "string",
      "defaultValue": "mistral-document-ai-2512",
      "description": "Foundry deployment id for Mistral Document AI; the activity falls back to this default when the document's stored model_id is not a Mistral deployment name."
    },
    "templateModelId": {
      "type": "string",
      "defaultValue": "cmo8w9bsx0009loe5e1rxwhau",
      "description": "Labeling TemplateModel id (documents table metadata.templateModelId overrides this when set). Mistral Document AI requests document_annotation from field_schema when non-empty."
    },
    "confidenceThreshold": { "type": "number", "defaultValue": 0.95, "description": "OCR confidence threshold for human review" },
    "preparedFileData": { "type": "object" },
    "ocrResult": { "type": "object" },
    "ocrResponse": { "type": "object", "description": "Raw Foundry OCR response, emitted alongside ocrResult so the benchmark sample workflow's persistOcrCache step can write it to benchmark_ocr_cache." },
    "cleanedResult": { "type": "object" },
    "averageConfidence": { "type": "number" },
    "requiresReview": { "type": "boolean", "defaultValue": false }
  },
  "nodes": {
    "prepareFileData": {
      "id": "prepareFileData",
      "type": "activity",
      "label": "Prepare File Data",
      "activityType": "file.prepare",
      "inputs": [
        { "port": "blobKey", "ctxKey": "blobKey" },
        { "port": "fileName", "ctxKey": "fileName" },
        { "port": "fileType", "ctxKey": "fileType" },
        { "port": "contentType", "ctxKey": "contentType" },
        { "port": "modelId", "ctxKey": "modelId" }
      ],
      "outputs": [{ "port": "preparedData", "ctxKey": "preparedFileData" }],
      "timeout": { "startToClose": "1m" },
      "retry": { "maximumAttempts": 3 }
    },
    "mistralAzureOcr": {
      "id": "mistralAzureOcr",
      "type": "activity",
      "label": "Mistral Document AI (Azure Foundry)",
      "activityType": "mistralAzureOcr.process",
      "inputs": [
        { "port": "fileData", "ctxKey": "preparedFileData" },
        { "port": "templateModelId", "ctxKey": "templateModelId" }
      ],
      "outputs": [
        { "port": "ocrResult", "ctxKey": "ocrResult" },
        { "port": "ocrResponse", "ctxKey": "ocrResponse" }
      ],
      "timeout": { "startToClose": "20m" },
      "retry": {
        "maximumAttempts": 30,
        "initialInterval": "15s",
        "backoffCoefficient": 1.5,
        "maximumInterval": "60s"
      }
    },
    "postOcrCleanup": {
      "id": "postOcrCleanup",
      "type": "activity",
      "label": "Post-OCR Cleanup",
      "activityType": "ocr.cleanup",
      "inputs": [{ "port": "ocrResult", "ctxKey": "ocrResult" }],
      "outputs": [{ "port": "cleanedResult", "ctxKey": "cleanedResult" }],
      "timeout": { "startToClose": "2m" },
      "retry": { "maximumAttempts": 3 }
    },
    "checkConfidence": {
      "id": "checkConfidence",
      "type": "activity",
      "label": "Check OCR Confidence",
      "activityType": "ocr.checkConfidence",
      "inputs": [
        { "port": "documentId", "ctxKey": "documentId" },
        { "port": "ocrResult", "ctxKey": "cleanedResult" },
        { "port": "threshold", "ctxKey": "confidenceThreshold" }
      ],
      "outputs": [
        { "port": "averageConfidence", "ctxKey": "averageConfidence" },
        { "port": "requiresReview", "ctxKey": "requiresReview" }
      ],
      "timeout": { "startToClose": "30s" },
      "retry": { "maximumAttempts": 3 }
    },
    "reviewSwitch": {
      "id": "reviewSwitch",
      "type": "switch",
      "label": "Needs Review?",
      "inputs": [{ "port": "requiresReview", "ctxKey": "requiresReview" }],
      "cases": [
        {
          "condition": {
            "operator": "equals",
            "left": { "ref": "ctx.requiresReview" },
            "right": { "literal": true }
          },
          "edgeId": "edge-switch-to-humanGate"
        }
      ],
      "defaultEdge": "edge-switch-to-store"
    },
    "humanReview": {
      "id": "humanReview",
      "type": "humanGate",
      "label": "Human Review",
      "signal": {
        "name": "humanApproval",
        "payloadSchema": {
          "approved": "boolean",
          "reviewer": "string",
          "comments": "string",
          "rejectionReason": "string",
          "annotations": "string"
        }
      },
      "timeout": "24h",
      "onTimeout": "fail"
    },
    "storeResults": {
      "id": "storeResults",
      "type": "activity",
      "label": "Store Results",
      "activityType": "ocr.storeResults",
      "inputs": [
        { "port": "documentId", "ctxKey": "documentId" },
        { "port": "ocrResult", "ctxKey": "cleanedResult" }
      ],
      "timeout": { "startToClose": "2m" },
      "retry": { "maximumAttempts": 5 }
    }
  },
  "edges": [
    { "id": "e-mz1", "source": "prepareFileData", "target": "mistralAzureOcr", "type": "normal" },
    { "id": "e-mz2", "source": "mistralAzureOcr", "target": "postOcrCleanup", "type": "normal" },
    { "id": "e-mz3", "source": "postOcrCleanup", "target": "checkConfidence", "type": "normal" },
    { "id": "e-mz4", "source": "checkConfidence", "target": "reviewSwitch", "type": "normal" },
    { "id": "edge-switch-to-humanGate", "source": "reviewSwitch", "target": "humanReview", "type": "conditional", "condition": "requiresReview" },
    { "id": "edge-switch-to-store", "source": "reviewSwitch", "target": "storeResults", "type": "conditional", "condition": "default" },
    { "id": "e-mz7", "source": "humanReview", "target": "storeResults", "type": "normal" }
  ],
  "nodeGroups": {
    "ocr-extraction": {
      "label": "OCR (Mistral on Foundry)",
      "description": "Mistral Document AI synchronous OCR via the Azure AI Foundry deployment",
      "icon": "scan",
      "color": "#f97316",
      "nodeIds": ["prepareFileData", "mistralAzureOcr"],
      "exposedParams": [
        {
          "label": "Foundry Deployment",
          "path": "ctx.modelId.defaultValue",
          "type": "select",
          "options": ["mistral-document-ai-2512"],
          "default": "mistral-document-ai-2512"
        }
      ]
    },
    "cleanup": {
      "label": "Post-Processing",
      "description": "Clean and normalize OCR results",
      "icon": "cleanup",
      "color": "#22c55e",
      "nodeIds": ["postOcrCleanup"]
    },
    "quality-gate": {
      "label": "Quality Gate",
      "description": "Check OCR confidence and decide if human review is needed",
      "icon": "quality",
      "color": "#fb923c",
      "nodeIds": ["checkConfidence", "reviewSwitch"],
      "exposedParams": [
        {
          "label": "Confidence Threshold",
          "path": "nodes.checkConfidence.parameters.threshold",
          "type": "number",
          "default": 0.95
        }
      ]
    },
    "human-review": {
      "label": "Human Review",
      "description": "Wait for human approval when confidence is low",
      "icon": "human",
      "color": "#ef4444",
      "nodeIds": ["humanReview"],
      "exposedParams": [
        {
          "label": "Review Timeout",
          "path": "nodes.humanReview.timeout",
          "type": "duration",
          "default": "24h"
        }
      ]
    },
    "store": {
      "label": "Store Results",
      "description": "Save processed results to database",
      "icon": "save",
      "color": "#8b5cf6",
      "nodeIds": ["storeResults"]
    }
  }
}
