# Mistral Document AI OCR (`mistralOcr.process` activity)
# https://docs.mistral.ai/capabilities/document_ai/basic_ocr/
MISTRAL_API_KEY=
# Set to true for CI/local tests without calling Mistral (deterministic mock OCRResult)
MOCK_MISTRAL_OCR=false

# Azure Document Intelligence Configuration
# Get these from your Azure Portal: https://portal.azure.com
# Navigate to your Document Intelligence resource -> Keys and Endpoint
# Endpoint must be the base URL the SDK appends paths to. If you use a path prefix
# (e.g. APIM or /project-name/documentintelligence), include it with no trailing slash:
#   https://your-host/sdpr-invoice-automation/documentintelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your-api-key-here

# When true, submit/poll OCR activities use synthetic responses (no calls to Azure).
# Use for load tests or local runs without Document Intelligence. Does not affect Nest backend routes that call Azure directly.
MOCK_AZURE_OCR=false

# Temporal Server Configuration
# Address of your Temporal server (default: localhost:7233 for local development)
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace (default: default)
TEMPORAL_NAMESPACE=default

# Task queue name for OCR processing workflows (default: ocr-processing)
TEMPORAL_TASK_QUEUE=ocr-processing

# Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_doc_intelligence?schema=public"

# Database Connection Pool
# Maximum number of database connections per worker pod (default: 3)
# Workers have lighter database load than backend-services
DB_POOL_MAX=3

# Azure OpenAI (optional - for LLM enrichment step when enableLlmEnrichment is true)
# Get these from your Azure OpenAI resource in Azure Portal
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional: set to true to redact PII (SIN, phone, $ amounts) in the extracted text sent to the LLM.
# ENRICHMENT_REDACT_PII=true

# MinIO Configuration (must match backend-services docker-compose port mapping)
# Note: MinIO API is accessible on host port 19000 (mapped to container port 9000)
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

BLOB_STORAGE_PROVIDER=minio # or "azure"

# if BLOB_STORAGE_PROVIDER azure, these must be provided
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
# Worker Concurrency Configuration
MAX_CONCURRENT_ACTIVITY_TASK_EXECUTIONS=10
MAX_CONCURRENT_WORKFLOW_TASK_EXECUTIONS=100
