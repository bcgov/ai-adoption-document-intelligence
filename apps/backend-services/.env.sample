# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_doc_intelligence?schema=public"

# BC Gov SSO Express Configuration
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3002
SSO_AUTH_SERVER_URL=https://dev.loginproxy.gov.bc.ca/auth/realms/standard/protocol/openid-connect
SSO_REALM=standard
SSO_CLIENT_ID=xxxxxxxxxxxxxxxx
SSO_CLIENT_SECRET=xxxxxx

# Azure Connection
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# Same as above but without /documentintelligence, todo: normalize
AZURE_DOCUMENT_INTELLIGENCE_TRAIN_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=

# Azure Document Intelligence Models (comma-separated list of allowed model IDs)
AZURE_DOC_INTELLIGENCE_MODELS=prebuilt-layout,sdpr-monthly-report-model

# Local storage path
LOCAL_BLOB_STORAGE_PATH="/test/blobs"

# Azure Blob Storage Configuration (for model training)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# Training Configuration
TRAINING_SAS_EXPIRY_DAYS=7
TRAINING_MIN_DOCUMENTS=5
TRAINING_POLL_INTERVAL_SECONDS=10
TRAINING_MAX_POLL_ATTEMPTS=60
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace (default: default)
TEMPORAL_NAMESPACE=default

# Task queue name for OCR processing workflows (default: ocr-processing)
TEMPORAL_TASK_QUEUE=ocr-processing

# Integration Test Configuration
# Used for integration testing - allows test scripts to authenticate with backend
TEST_API_KEY=xxxxxx

# Workflow template to use for integration testing (default: standard-ocr-workflow)
# Options: standard-ocr-workflow, multi-page-report-workflow
WORKFLOW_TEMPLATE=standard-ocr-workflow

# Test file to use for integration testing (default: test-document.jpg)
# File must exist in apps/backend-services/integration-tests/
TEST_FILE=test-document.jpg

LOG_LEVEL=debug