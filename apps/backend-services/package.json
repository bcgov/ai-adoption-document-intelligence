{
	"name": "ai-ocr-backend-services",
	"version": "1.0.0",
	"description": "AI OCR Backend Services",
	"author": "",
	"private": true,
	"license": "Apache-2.0",
	"scripts": {
		"build": "npm run db:generate && nest build",
		"build:prod": "NODE_ENV=production npm run db:generate && nest build",
		"build:logging": "cd ../../packages/logging && npm run build",
		"format": "prettier --write \"src/**/*.ts\"",
		"start": "nest start",
		"start:dev": "npm run build:logging && CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=1000 nest start --watch --preserveWatchOutput",
		"start:prod": "node dist/main",
		"lint": "npx @biomejs/biome check",
		"lint:fix": "npm run lint -- --write",
		"type-check": "tsc --noEmit",
		"test": "jest --passWithNoTests",
		"test:watch": "jest --watch",
		"test:int": "./integration-tests/run.sh",
		"test:int:workflow": "ts-node -r tsconfig-paths/register integration-tests/test-graph-workflow.ts",
		"test:int:workflow:with-worker": "MANAGE_WORKER=true ts-node -r tsconfig-paths/register integration-tests/test-graph-workflow.ts",
		"test:cov": "jest --coverage",
		"db:generate": "node ../shared/scripts/generate-prisma.js",
		"db:migrate": "prisma migrate dev",
		"db:reset": "prisma migrate reset",
		"db:status": "prisma migrate status",
		"db:studio": "BROWSER=none prisma studio --port 5555",
		"db:seed": "prisma db seed"
	},
	"dependencies": {
    "@ai-di/blob-storage-paths": "file:../../packages/blob-storage-paths",
		"@ai-di/shared-logging": "file:../../packages/logging",
		"@aws-sdk/client-s3": "^3.990.0",
		"@azure-rest/ai-document-intelligence": "1.1.0",
		"@azure/storage-blob": "12.30.0",
		"@nestjs/axios": "4.0.1",
		"@nestjs/common": "^11.1.12",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.12",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "11.1.13",
		"@nestjs/schedule": "6.1.0",
		"@nestjs/swagger": "11.2.5",
		"@nestjs/throttler": "^6.5.0",
		"@prisma/adapter-pg": "7.2.0",
		"@prisma/client": "7.2.0",
		"@temporalio/client": "^1.10.0",
		"@types/helmet": "^0.0.48",
		"ajv": "^8.17.1",
		"bcrypt": "^6.0.0",
		"body-parser": "^1.20.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.2.3",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"jwks-rsa": "^3.2.0",
		"openid-client": "^6.8.2",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"pdf-lib": "^1.17.1",
		"pg": "^8.16.3",
		"prisma": "7.2.0",
		"prom-client": "^15.1.3",
		"rxjs": "^7.8.2",
		"sharp": "^0.34.5",
		"uuid": "13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@nestjs/cli": "^11.0.13",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "11.1.9",
		"@swc/cli": "^0.7.9",
		"@swc/core": "^1.15.3",
		"@testcontainers/postgresql": "11.10.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "5.0.6",
		"@types/jest": "30.0.0",
		"@types/multer": "2.0.0",
		"@types/node": "24.10.1",
		"@types/passport-jwt": "^4.0.1",
		"@types/supertest": "6.0.3",
		"@types/uuid": "11.0.0",
		"import-local": "3.2.0",
		"jest": "30.2.0",
		"source-map-support": "^0.5.21",
		"supertest": "7.1.4",
		"testcontainers": "11.10.0",
		"ts-jest": "29.4.5",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.0.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s",
			"!**/*.spec.ts",
			"!**/node_modules/**",
			"!**/generated/**",
			"!main.ts"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node",
		"transformIgnorePatterns": [
			"node_modules/(?!(uuid|openid-client|oauth4webapi|jose))"
		],
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/$1",
			"^@generated/(.*)$": "<rootDir>/generated/$1"
		},
		"setupFiles": [
			"./testUtils/testSetup.ts"
		],
		"coverageThreshold": {
			"global": {
				"branches": 70,
				"functions": 70,
				"lines": 70,
				"statements": 70
			}
		}
	}
}
