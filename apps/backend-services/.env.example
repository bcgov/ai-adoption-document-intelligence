NODE_ENV=test

# PostgreSQL Configuration
POSTGRES_DB=ai_doc_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO Configuration
# MinIO is used for S3-compatible object storage (DVC remote, MLflow artifacts, benchmark outputs)
# Note: MinIO API is accessible on host port 19000 (mapped to container port 9000)
#       MinIO Console is accessible on host port 19001 (mapped to container port 9001)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MLflow Configuration
# MLflow S3 endpoint points to MinIO (internal service-to-service communication uses port 9000)
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# AWS SDK credentials for MLflow to access MinIO (should match MinIO credentials)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MLflow Database Configuration (internal)
# The MLflow database is automatically created by the init-mlflow-db.sql script
# Connection string: postgresql://mlflow:mlflow_password@postgres:5432/mlflow

# MinIO Configuration for Application (used by MinioBlobStorageService and DvcService)
# These should match the MinIO credentials above
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Dataset Git Repository Credentials
# Used by DvcService to clone and manage dataset repositories
# For local development with file:// URLs, these can be omitted
# For remote repositories (https://, git@), provide valid credentials
DATASET_GIT_USERNAME=
DATASET_GIT_PASSWORD=

# Default Dataset Repository Path (optional)
# Default location for dataset repositories, supports tilde (~) expansion
# Used as a suggestion/default in the frontend and for local development
# Example: ~/Github/datasets-repo or /path/to/datasets-repo
DEFAULT_DATASET_REPOSITORY_PATH=~/Github/datasets-repo
DVC_BINARY_PATH=/home/xxxx/.pyenv/versions/3.11.14/bin/dvc
