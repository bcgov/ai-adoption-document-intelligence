<policies>
    <inbound>
        <base />

        <!-- Path-based routing to backend services -->
        <choose>
            <!-- Document Intelligence: /documentintelligence/* -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;documentintelligence&quot;))">
                <!-- Authenticate with managed identity -->
                <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
                <set-backend-service base-url="${docint_endpoint}" />
            </when>

            <!-- AI Foundry / OpenAI: /openai/* -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;))">
                <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
                <set-backend-service base-url="${ai_foundry_endpoint}" />
            </when>

            <!-- Storage: /storage/* -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;storage&quot;))">
                <authentication-managed-identity resource="https://storage.azure.com" />
                <!-- Strip /storage prefix before forwarding -->
                <rewrite-uri template="@{
                    var path = context.Request.Url.Path;
                    var idx = path.ToLower().IndexOf(&quot;storage/&quot;);
                    return idx >= 0 ? &quot;/&quot; + path.Substring(idx + 8) : path;
                }" />
                <set-backend-service base-url="${storage_endpoint}" />
            </when>

            <otherwise>
                <return-response>
                    <set-status code="404" reason="Not Found" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        return new JObject(
                            new JProperty("error", new JObject(
                                new JProperty("code", "404"),
                                new JProperty("message", "Unknown service path. Use /documentintelligence/*, /openai/*, or /storage/*"),
                                new JProperty("requestId", context.RequestId.ToString())
                            ))
                        ).ToString();
                    }</set-body>
                </return-response>
            </otherwise>
        </choose>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
