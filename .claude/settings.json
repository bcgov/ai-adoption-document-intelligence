{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run test)",
      "Bash(npm run db:generate)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(cd apps/*)",
      "Bash(cd scripts/*)",
      "mcp__playwright__browser_press_key",
      "Bash(npm test:*)",
      "Bash(npx jest:*)",
      "Bash(npm run:*)",
      "Bash(helm lint:*)",
      "Bash(helm template:*)",
      "Bash(docker compose:*)",
      "Bash(kustomize build:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.config/bcgov-di/**)",
      "Bash(cat *.env*)",
      "Bash(cat **/.env*)",
      "Bash(cat ~/.config/bcgov-di/**)",
      "Bash(env)",
      "Bash(printenv*)"
    ],
    "disableBypassPermissionsMode": "disable",
    "defaultMode": "acceptEdits",
    "model": "sonnet"
  }
}
