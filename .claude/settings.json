{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "model": "sonnet",
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run test)",
      "Bash(npm run db:generate)",

      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",

      "Bash(cd apps/*)",
      "Bash(cd scripts/*)"
    ]
  }
}
