{
  "name": "@ai-di/graph-insertion-slots",
  "version": "1.0.0",
  "description": "Shared graph insertion-slot helpers for backend-services and temporal worker",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": "src",
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["**/*.ts", "!**/*.test.ts"]
  }
}
