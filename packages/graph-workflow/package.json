{
  "name": "@ai-di/graph-workflow",
  "version": "1.0.0",
  "description": "Shared graph workflow types and validation logic",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./kinds": {
      "types": "./dist/kinds/index.d.ts",
      "import": "./dist/kinds/index.js",
      "default": "./dist/kinds/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "jest"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "json5": "2.2.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": "src",
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.test.ts"
    ]
  }
}
